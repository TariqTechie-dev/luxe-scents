<!DOCTYPE html>
<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title><%= title %></title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet" />
    <!-- Icons -->
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
    <!-- Main JS (Tailwind Config) -->
    <script src="/js/tailwind-config.js"></script>
</head>

<body
    class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 min-h-screen flex flex-col transition-colors duration-300">
    <!-- Top Navigation Bar -->
    <header
        class="w-full border-b border-slate-200 dark:border-accent-dark bg-white/50 dark:bg-background-dark/50 backdrop-blur-md sticky top-0 z-50 px-6 lg:px-20 py-4">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <div class="flex items-center gap-12">
                <a href="/" class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary text-3xl">local_florist</span>
                    <h2 class="text-xl font-extrabold tracking-widest gold-gradient-text"><%= siteName %></h2>
                </a>
                <nav class="hidden md:flex items-center gap-8">
                    <a class="text-sm font-medium hover:text-primary transition-colors" href="/shop">Collections</a>
                    <a class="text-sm font-medium hover:text-primary transition-colors" href="/orders">My Orders</a>
                    <a class="text-sm font-medium hover:text-primary transition-colors" href="/dashboard">Dashboard</a>
                </nav>
            </div>
            <div class="flex items-center gap-6">
                <a href="/cart"
                    class="material-symbols-outlined p-2 hover:bg-slate-100 dark:hover:bg-accent-dark rounded-full transition-colors">
                    shopping_bag
                </a>
                <a href="/dashboard"
                    class="material-symbols-outlined p-2 hover:bg-slate-100 dark:hover:bg-accent-dark rounded-full transition-colors">
                    person
                </a>
            </div>
        </div>
    </header>

    <main class="flex-1 max-w-4xl mx-auto px-6 py-12 lg:py-20">
        <!-- Success Header -->
        <div class="text-center mb-12">
            <div
                class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-primary/10 mb-6 luxury-border">
                <span class="material-symbols-outlined text-primary text-5xl">check_circle</span>
            </div>
            <h1 class="text-4xl font-extrabold mb-3 tracking-tight">Order Confirmed</h1>
            <p class="text-slate-500 dark:text-slate-400 text-lg mb-6">
                Thank you for your purchase, <%= userName %>. We are preparing your order.
            </p>

            <% if (order) { %>
                <div
                    class="inline-flex items-center gap-3 bg-slate-100 dark:bg-accent-dark px-6 py-2 rounded-full border border-slate-200 dark:border-slate-700">
                    <span class="text-xs font-bold uppercase tracking-widest text-slate-400">Order ID</span>
                    <span class="font-mono text-primary font-bold">#ORD-<%= order._id.toString().slice(-6).toUpperCase() %></span>
                </div>
            <% } %>
        </div>

        <% if (order) { %>
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                <!-- Left Column: Summary & Delivery -->
                <div class="lg:col-span-8 space-y-6">
                    <!-- Order Summary -->
                    <div class="bg-white dark:bg-surface-dark rounded-xl luxury-border overflow-hidden">
                        <div
                            class="px-6 py-4 border-b border-slate-100 dark:border-accent-dark flex justify-between items-center">
                            <h3 class="font-bold text-lg">Order Summary</h3>
                        </div>
                        <div class="p-0">
                            <div class="divide-y divide-slate-100 dark:divide-accent-dark">
                                <% order.items.forEach(function(item) { %>
                                    <div class="p-6 flex gap-4 items-center">
                                        <div
                                            class="w-20 h-20 rounded-lg bg-slate-100 dark:bg-accent-dark flex-shrink-0 flex items-center justify-center overflow-hidden">
                                            <span class="material-symbols-outlined text-primary text-3xl">local_florist</span>
                                        </div>
                                        <div class="flex-1">
                                            <h4 class="font-bold"><%= item.name %></h4>
                                            <p class="text-sm text-slate-500 dark:text-slate-400">Qty: <%= item.quantity %></p>
                                        </div>
                                        <div class="text-right">
                                            <p class="font-bold">$<%= (item.price * item.quantity).toFixed(2) %></p>
                                            <p class="text-sm text-slate-500">$<%= item.price.toFixed(2) %> each</p>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    </div>

                    <!-- Shipping & Delivery Grid -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="bg-white dark:bg-surface-dark p-6 rounded-xl luxury-border">
                            <div class="flex items-center gap-3 mb-4">
                                <span class="material-symbols-outlined text-primary">local_shipping</span>
                                <h3 class="font-bold">Shipping Address</h3>
                            </div>
                            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
                                <%= userName %><br />
                                <%= order.shippingAddress.street %><br />
                                <%= order.shippingAddress.city %><%= order.shippingAddress.state ? ', ' + order.shippingAddress.state : '' %> <%= order.shippingAddress.zip %><br />
                                <%= order.shippingAddress.country %>
                            </p>
                        </div>
                        <div class="bg-primary/5 dark:bg-primary/5 p-6 rounded-xl border border-primary/20">
                            <div class="flex items-center gap-3 mb-4">
                                <span class="material-symbols-outlined text-primary">calendar_month</span>
                                <h3 class="font-bold">Order Status</h3>
                            </div>
                            <p class="text-2xl font-black text-primary mb-1"><%= order.status %></p>
                            <p class="text-sm text-slate-500 dark:text-slate-400 italic">Payment: <%= order.paymentStatus %></p>
                        </div>
                    </div>
                </div>

                <!-- Right Column: Totals & Next Steps -->
                <div class="lg:col-span-4 space-y-6">
                    <!-- Order Total -->
                    <div class="bg-white dark:bg-surface-dark p-6 rounded-xl luxury-border">
                        <h3 class="font-bold text-lg mb-4">Summary</h3>
                        <div class="space-y-3 text-sm">
                            <div class="flex justify-between">
                                <span class="text-slate-500">Subtotal</span>
                                <span class="font-medium">$<%= order.totalAmount.toFixed(2) %></span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-slate-500">Shipping</span>
                                <span class="font-medium">Free</span>
                            </div>
                            <div
                                class="pt-3 border-t border-slate-100 dark:border-accent-dark flex justify-between items-baseline">
                                <span class="font-bold text-base">Total</span>
                                <span class="text-xl font-black text-primary">$<%= order.totalAmount.toFixed(2) %></span>
                            </div>
                        </div>
                    </div>

                    <!-- Next Steps/Timeline -->
                    <div class="bg-slate-5 dark:bg-accent-dark p-6 rounded-xl">
                        <h3 class="font-bold mb-6 flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm">info</span>
                            Next Steps
                        </h3>
                        <div
                            class="space-y-6 relative before:content-[''] before:absolute before:left-3 before:top-2 before:bottom-2 before:w-px before:bg-primary/30">
                            <div class="relative pl-8">
                                <div
                                    class="absolute left-1 top-1 w-4 h-4 rounded-full bg-primary border-4 border-background-dark">
                                </div>
                                <p class="text-sm font-bold">Order Received</p>
                                <p class="text-xs text-slate-500">Just now</p>
                            </div>
                            <div class="relative pl-8">
                                <div
                                    class="absolute left-1 top-1 w-4 h-4 rounded-full bg-accent-dark border-4 border-slate-600">
                                </div>
                                <p class="text-sm font-medium text-slate-400">Processing & Quality Control</p>
                                <p class="text-xs text-slate-500">Estimated: Tomorrow</p>
                            </div>
                            <div class="relative pl-8">
                                <div
                                    class="absolute left-1 top-1 w-4 h-4 rounded-full bg-accent-dark border-4 border-slate-600">
                                </div>
                                <p class="text-sm font-medium text-slate-400">Shipped with Tracking</p>
                                <p class="text-xs text-slate-500">Notification via Email</p>
                            </div>
                        </div>
                    </div>

                    <!-- Personalized Note -->
                    <div class="text-center p-4">
                        <p class="text-xs text-slate-500 uppercase tracking-[0.2em] font-medium leading-relaxed">
                            Each bottle is hand-selected with care. Thank you for choosing <%= siteName %>.
                        </p>
                    </div>
                </div>
            </div>
        <% } else { %>
            <!-- Fallback: no order data available -->
            <div class="text-center py-8">
                <p class="text-slate-400 mb-4">No recent order data to display. It may have already been viewed.</p>
            </div>
        <% } %>

        <!-- Action Footer -->
        <div class="mt-16 flex flex-col md:flex-row items-center justify-center gap-4">
            <a class="w-full md:w-auto px-10 py-4 bg-primary text-black font-extrabold rounded-lg hover:shadow-lg hover:shadow-primary/20 transition-all flex items-center justify-center gap-2 uppercase tracking-wider text-sm"
                href="/shop">
                Continue Shopping
                <span class="material-symbols-outlined">arrow_forward</span>
            </a>
            <a class="w-full md:w-auto px-10 py-4 bg-transparent border border-slate-300 dark:border-accent-dark text-slate-600 dark:text-slate-300 font-bold rounded-lg hover:bg-slate-100 dark:hover:bg-accent-dark transition-all text-sm uppercase tracking-wider text-center"
                href="/orders">
                View Order History
            </a>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>

</html>
