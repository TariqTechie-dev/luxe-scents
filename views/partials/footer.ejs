<footer class="mt-auto border-t border-surface-border bg-background-dark text-white">
  <!-- Main footer content -->
  <div class="mx-auto grid w-full max-w-7xl grid-cols-1 gap-10 px-4 py-16 sm:px-6 md:grid-cols-2 lg:grid-cols-4 lg:px-8">
    <!-- Brand -->
    <div class="space-y-5">
      <a href="/" class="inline-flex items-center gap-3 text-white hover:text-primary transition-colors" aria-label="<%= typeof siteName !== 'undefined' ? siteName : 'Luxe Scents' %> home">
        <span class="inline-flex size-11 items-center justify-center rounded-full border border-primary/30 bg-primary/10 text-primary">
          <span class="material-symbols-outlined text-[26px]" aria-hidden="true">local_florist</span>
        </span>
        <span class="font-display text-xl font-bold uppercase tracking-[0.22em]">
          <%= typeof siteName !== 'undefined' ? siteName : 'Luxe Scents' %>
        </span>
      </a>

      <p class="max-w-xs text-sm leading-6 text-zinc-400">
        Exquisite fragrances for the modern connoisseur.
      </p>

      <div class="flex items-center gap-3" aria-label="Social links">
        <a href="#" class="inline-flex size-10 items-center justify-center rounded-full border border-white/20 bg-white/[0.06] text-zinc-100 transition hover:border-primary/70 hover:bg-primary/10 hover:text-primary" aria-label="Facebook">
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M14 8.5V6.75c0-.72.48-.89.82-.89h2.09V2.66L14.03 2.65c-3.2 0-3.93 2.39-3.93 3.92V8.5H7.5v3.6h2.6V22h3.9v-9.9h2.65l.35-3.6H14Z" />
          </svg>
        </a>
        <a href="#" class="inline-flex size-10 items-center justify-center rounded-full border border-white/20 bg-white/[0.06] text-zinc-100 transition hover:border-primary/70 hover:bg-primary/10 hover:text-primary" aria-label="Instagram">
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
          </svg>
        </a>
        <a href="#" class="inline-flex size-10 items-center justify-center rounded-full border border-white/20 bg-white/[0.06] text-zinc-100 transition hover:border-primary/70 hover:bg-primary/10 hover:text-primary" aria-label="YouTube">
          <svg class="size-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M21.58 7.2a3 3 0 0 0-2.1-2.12C17.62 4.58 12 4.58 12 4.58s-5.62 0-7.48.5A3 3 0 0 0 2.42 7.2 31.2 31.2 0 0 0 1.92 12a31.2 31.2 0 0 0 .5 4.8 3 3 0 0 0 2.1 2.12c1.86.5 7.48.5 7.48.5s5.62 0 7.48-.5a3 3 0 0 0 2.1-2.12 31.2 31.2 0 0 0 .5-4.8 31.2 31.2 0 0 0-.5-4.8ZM10 15.45v-6.9L15.75 12 10 15.45Z" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Quick links -->
    <nav aria-label="Quick links">
      <h2 class="mb-5 text-sm font-bold uppercase tracking-[0.22em] text-primary">Quick Links</h2>
      <ul class="space-y-3 text-sm text-zinc-400">
        <li><a href="/shop" class="transition hover:text-primary">Shop</a></li>
        <li><a href="/shop" class="transition hover:text-primary">Collections</a></li>
        <li><a href="#" class="transition hover:text-primary">About Us</a></li>
        <li><a href="#" class="transition hover:text-primary">Contact</a></li>
      </ul>
    </nav>

    <!-- Customer care -->
    <nav aria-label="Customer care">
      <h2 class="mb-5 text-sm font-bold uppercase tracking-[0.22em] text-primary">Customer Care</h2>
      <ul class="space-y-3 text-sm text-zinc-400">
        <li><a href="/policies#shipping" class="transition hover:text-primary">Shipping Policy</a></li>
        <li><a href="/policies#returns" class="transition hover:text-primary">Returns &amp; Exchanges</a></li>
        <li><a href="/policies#faq" class="transition hover:text-primary">FAQ</a></li>
        <li><a href="/orders" class="transition hover:text-primary">Track Order</a></li>
      </ul>
    </nav>

    <!-- Newsletter -->
    <div>
      <h2 class="mb-5 text-sm font-bold uppercase tracking-[0.22em] text-primary">Newsletter</h2>
      <p class="mb-5 max-w-sm text-sm leading-6 text-zinc-400">
        Receive private releases, seasonal edits, and exclusive fragrance notes.
      </p>

      <form action="#" method="POST" class="space-y-3" onsubmit="event.preventDefault();">
        <label for="footer-newsletter-email" class="sr-only">Email address</label>
        <div class="flex overflow-hidden rounded-lg border border-surface-border bg-input-bg focus-within:border-primary/70 focus-within:ring-1 focus-within:ring-primary/50">
          <input
            id="footer-newsletter-email"
            name="email"
            type="email"
            required
            autocomplete="email"
            placeholder="Email address"
            class="min-w-0 flex-1 border-0 bg-transparent px-5 py-3 text-sm text-white placeholder:text-zinc-400 focus:ring-0 sm:px-6"
          />
          <button type="submit" class="shrink-0 bg-primary px-5 py-3 text-sm font-bold text-neutral-950 transition hover:bg-primary-hover">
            Subscribe
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="mx-auto flex w-full max-w-7xl flex-col gap-4 px-4 py-5 text-sm text-zinc-500 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
      <p>&copy; 2026 <%= typeof siteName !== 'undefined' ? siteName : 'Luxe Scents' %>. All rights reserved.</p>
      <div class="inline-flex items-center gap-2 text-zinc-400">
        <span class="material-symbols-outlined text-[18px] text-primary" aria-hidden="true">payments</span>
        <span>Cash on delivery</span>
      </div>
    </div>
  </div>
</footer>
