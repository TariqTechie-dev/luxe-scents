<!DOCTYPE html>
<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/tailwind-config.js"></script>
    <style>
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #221e10; }
        ::-webkit-scrollbar-thumb { background: #4a4025; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #f4c025; }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-white antialiased min-h-screen flex flex-col">
    <!-- Header -->
    <header class="w-full border-b border-slate-200 dark:border-accent-dark bg-white/50 dark:bg-background-dark/50 backdrop-blur-md sticky top-0 z-50 px-6 lg:px-20 py-4">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <a href="/" class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary text-3xl">local_florist</span>
                <h2 class="text-xl font-extrabold tracking-widest gold-gradient-text"><%= siteName %></h2>
            </a>
            <nav class="flex items-center gap-4">
                <a href="/orders" class="text-sm font-medium text-primary hover:underline">← Back to Orders</a>
                <a href="/dashboard" class="text-sm font-medium hover:text-primary transition-colors">Dashboard</a>
            </nav>
        </div>
    </header>

    <%
        const orderId = order._id.toString().slice(-6).toUpperCase();
        const orderDate = new Date(order.createdAt).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
        const orderTime = new Date(order.createdAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
    %>

    <main class="flex-1 max-w-4xl mx-auto px-6 py-12">
        <!-- Order Header -->
        <div class="mb-10">
            <div class="flex flex-col sm:flex-row sm:items-center gap-4 mb-3">
                <h1 class="text-3xl md:text-4xl font-bold tracking-tight">Order #ORD-<%= orderId %></h1>
                <%
                    let statusColor = 'primary';
                    if (order.status === 'Shipped') statusColor = 'blue-400';
                    else if (order.status === 'Delivered') statusColor = 'green-400';
                    else if (order.status === 'Cancelled') statusColor = 'red-400';
                    else if (order.status === 'Processing') statusColor = 'yellow-400';
                %>
                <span class="inline-flex items-center gap-1.5 rounded-full bg-<%= statusColor %>/10 px-4 py-1.5 text-sm font-bold text-<%= statusColor %> ring-1 ring-inset ring-<%= statusColor %>/20 w-fit">
                    <span class="size-2 rounded-full bg-<%= statusColor %>"></span>
                    <%= order.status %>
                </span>
            </div>
            <p class="text-text-muted text-sm">Placed on <%= orderDate %> at <%= orderTime %></p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            <!-- Left Column: Items & Shipping -->
            <div class="lg:col-span-8 space-y-6">
                <!-- Order Items -->
                <div class="bg-white dark:bg-surface-dark rounded-xl border border-border-dark overflow-hidden">
                    <div class="px-6 py-4 border-b border-border-dark">
                        <h3 class="font-bold text-lg">Items Ordered</h3>
                    </div>
                    <div class="divide-y divide-border-dark">
                        <% order.items.forEach(function(item) { %>
                            <div class="p-6 flex gap-4 items-center">
                                <div class="w-16 h-16 rounded-lg bg-primary/10 flex-shrink-0 flex items-center justify-center">
                                    <span class="material-symbols-outlined text-primary text-2xl">local_florist</span>
                                </div>
                                <div class="flex-1">
                                    <h4 class="font-bold"><%= item.name %></h4>
                                    <p class="text-sm text-text-muted">Qty: <%= item.quantity %></p>
                                </div>
                                <div class="text-right">
                                    <p class="font-bold text-primary">$<%= (item.price * item.quantity).toFixed(2) %></p>
                                    <p class="text-xs text-text-muted">$<%= item.price.toFixed(2) %> each</p>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </div>

                <!-- Shipping Address -->
                <div class="bg-white dark:bg-surface-dark p-6 rounded-xl border border-border-dark">
                    <div class="flex items-center gap-3 mb-4">
                        <span class="material-symbols-outlined text-primary">local_shipping</span>
                        <h3 class="font-bold">Shipping Address</h3>
                    </div>
                    <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
                        <%= order.shippingAddress.street %><br />
                        <%= order.shippingAddress.city %><%= order.shippingAddress.state ? ', ' + order.shippingAddress.state : '' %> <%= order.shippingAddress.zip %><br />
                        <%= order.shippingAddress.country %>
                    </p>
                </div>
            </div>

            <!-- Right Column: Summary -->
            <div class="lg:col-span-4 space-y-6">
                <div class="bg-white dark:bg-surface-dark p-6 rounded-xl border border-border-dark">
                    <h3 class="font-bold text-lg mb-4">Order Summary</h3>
                    <div class="space-y-3 text-sm">
                        <div class="flex justify-between">
                            <span class="text-text-muted">Subtotal</span>
                            <span class="font-medium">$<%= order.totalAmount.toFixed(2) %></span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-text-muted">Shipping</span>
                            <span class="font-medium text-text-gold">Free</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-text-muted">Payment</span>
                            <span class="font-medium"><%= order.paymentStatus %></span>
                        </div>
                        <div class="pt-3 border-t border-border-dark flex justify-between items-baseline">
                            <span class="font-bold text-base">Total</span>
                            <span class="text-xl font-black text-primary">$<%= order.totalAmount.toFixed(2) %></span>
                        </div>
                    </div>
                </div>

                <!-- Timeline -->
                <div class="bg-accent-dark p-6 rounded-xl">
                    <h3 class="font-bold mb-6 flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">info</span>
                        Order Timeline
                    </h3>
                    <div class="space-y-6 relative before:content-[''] before:absolute before:left-3 before:top-2 before:bottom-2 before:w-px before:bg-primary/30">
                        <div class="relative pl-8">
                            <div class="absolute left-1 top-1 w-4 h-4 rounded-full bg-primary border-4 border-background-dark"></div>
                            <p class="text-sm font-bold">Order Placed</p>
                            <p class="text-xs text-text-muted"><%= orderDate %></p>
                        </div>
                        <% if (['Processing', 'Shipped', 'Delivered'].includes(order.status)) { %>
                            <div class="relative pl-8">
                                <div class="absolute left-1 top-1 w-4 h-4 rounded-full bg-primary border-4 border-background-dark"></div>
                                <p class="text-sm font-bold">Processing</p>
                                <p class="text-xs text-text-muted">Your order is being prepared</p>
                            </div>
                        <% } %>
                        <% if (['Shipped', 'Delivered'].includes(order.status)) { %>
                            <div class="relative pl-8">
                                <div class="absolute left-1 top-1 w-4 h-4 rounded-full bg-blue-400 border-4 border-background-dark"></div>
                                <p class="text-sm font-bold">Shipped</p>
                                <p class="text-xs text-text-muted">On its way to you</p>
                            </div>
                        <% } %>
                        <% if (order.status === 'Delivered') { %>
                            <div class="relative pl-8">
                                <div class="absolute left-1 top-1 w-4 h-4 rounded-full bg-green-400 border-4 border-background-dark"></div>
                                <p class="text-sm font-bold">Delivered</p>
                                <p class="text-xs text-text-muted">Successfully delivered</p>
                            </div>
                        <% } %>
                        <% if (order.status === 'Cancelled') { %>
                            <div class="relative pl-8">
                                <div class="absolute left-1 top-1 w-4 h-4 rounded-full bg-red-400 border-4 border-background-dark"></div>
                                <p class="text-sm font-bold text-red-400">Cancelled</p>
                                <p class="text-xs text-text-muted">This order was cancelled</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Footer -->
        <div class="mt-12 flex flex-col md:flex-row items-center justify-center gap-4">
            <a class="w-full md:w-auto px-10 py-4 bg-primary text-black font-extrabold rounded-lg hover:shadow-lg hover:shadow-primary/20 transition-all flex items-center justify-center gap-2 uppercase tracking-wider text-sm"
                href="/shop">
                Continue Shopping
                <span class="material-symbols-outlined">arrow_forward</span>
            </a>
            <a class="w-full md:w-auto px-10 py-4 bg-transparent border border-border-dark text-slate-300 font-bold rounded-lg hover:bg-accent-dark transition-all text-sm uppercase tracking-wider text-center"
                href="/orders">
                All Orders
            </a>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>

</html>
