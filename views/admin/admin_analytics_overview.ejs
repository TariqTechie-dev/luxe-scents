<!DOCTYPE html>
<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Analytics — <%= siteName %> Admin</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link
        href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&amp;family=Noto+Sans:wght@300..800&amp;display=swap"
        rel="stylesheet" />
    <!-- Material Symbols -->
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
    <!-- Main JS (Tailwind Config) -->
    <script src="/js/tailwind-config.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        /* Custom scrollbar for webkit */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #221e10;
        }

        ::-webkit-scrollbar-thumb {
            background: #493f22;
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #f4c025;
        }

        .glass-panel {
            background: rgba(45, 40, 26, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(244, 192, 37, 0.1);
        }
    </style>
</head>

<body
    class="font-display bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 antialiased selection:bg-primary selection:text-black h-screen overflow-hidden flex">
    <!-- Side Navigation -->
    <aside
        class="hidden md:flex flex-col w-64 h-full border-r border-[#493f22] bg-background-dark shrink-0 transition-all duration-300">
        <div class="flex flex-col h-full p-4">
            <!-- Brand -->
            <div class="flex items-center gap-3 px-2 py-6 mb-4">
                <div class="bg-center bg-no-repeat bg-cover rounded-full size-10 shadow-[0_0_15px_rgba(244,192,37,0.3)]"
                    data-alt="Luxury gold perfume bottle icon"
                    style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuBaTkoZge5gaapf-z7r7NxgePfFeKn-KvW3IXUtS1jkPQcnt3frBCsMbmpYHjUa2QGuxWZDaQo3dHYGv8FnZm_88_eSEyOcjjnW3fWDyV8GCix4TRzXhovzwI7riiRDE9Mup9AtmdSYFzfblvTa8mePZSFlQj_ezAroxmFG4_cHlM5fty3_OwrTPCMHhPRr9yOp8_q1AU9DjLWc5fzxo0fTsc7d2bZq1p1vEoWDPcPEh68wm2YgYSscJLNqdjeQRTswimVTrqfGQSpe");'>
                </div>
                <div class="flex flex-col">
                    <h1 class="text-white text-lg font-bold tracking-tight">Luxe Scents</h1>
                    <p class="text-primary/80 text-xs font-medium uppercase tracking-widest">Admin</p>
                </div>
            </div>
            <!-- Navigation Links -->
            <nav class="flex flex-col gap-2 flex-1">
                <a class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-[#493f22]/30 text-[#cbbc90] hover:text-white transition-all group"
                    href="/">
                    <span class="material-symbols-outlined group-hover:text-primary transition-colors">dashboard</span>
                    <span class="text-white text-sm font-semibold">Dashboard</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-[#493f22]/30 text-[#cbbc90] hover:text-white transition-all group"
                    href="/admin/products">
                    <span
                        class="material-symbols-outlined group-hover:text-primary transition-colors">inventory_2</span>
                    <span class="text-sm font-medium">Products</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-[#493f22]/30 text-[#cbbc90] hover:text-white transition-all group"
                    href="/admin/orders">
                    <span
                        class="material-symbols-outlined group-hover:text-primary transition-colors">shopping_cart</span>
                    <span class="text-sm font-medium">Orders</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-[#493f22]/30 text-[#cbbc90] hover:text-white transition-all group"
                    href="#">
                    <span class="material-symbols-outlined group-hover:text-primary transition-colors">group</span>
                    <span class="text-sm font-medium">Users</span>
                </a>
                <!-- Active Link -->
                <a class="flex items-center gap-3 px-4 py-3 rounded-lg bg-primary/10 border border-primary/20 group transition-all"
                    href="/admin/analytics">
                    <span
                        class="material-symbols-outlined text-primary group-hover:scale-110 transition-transform">analytics</span>
                    <span class="text-sm font-medium">Analytics</span>
                </a>
            </nav>
            <!-- Bottom Settings -->
            <div class="mt-auto pt-4 border-t border-[#493f22]">
                <a class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-[#493f22]/30 text-[#cbbc90] hover:text-white transition-all group"
                    href="#">
                    <span class="material-symbols-outlined group-hover:text-primary transition-colors">settings</span>
                    <span class="text-sm font-medium">Settings</span>
                </a>
                   
                <!-- Logout via POST form for CSRF protection -->
                <form action="/logout" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="flex items-center gap-3 px-4 py-3 rounded-lg group hover:bg-red-900/20 transition-colors w-full">
                        <span class="material-symbols-outlined text-text-muted group-hover:text-red-400">logout</span>
                        <span class="text-text-muted group-hover:text-red-400 font-medium text-sm">Logout</span>
                    </button>
                </form>
         
            </div>
        </div>
    </aside>
    <!-- Main Content -->
    <main class="flex-1 flex flex-col h-full overflow-hidden bg-background-dark relative">
        <!-- Background decorative glow -->
        <div
            class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[120px] pointer-events-none">
        </div>
        <!-- Header -->
        <header
            class="h-16 flex items-center justify-between px-8 py-3 border-b border-[#493f22] bg-background-dark/95 backdrop-blur z-20 shrink-0">
            <div class="flex items-center gap-4 text-white">
                <button class="md:hidden text-white">
                    <span class="material-symbols-outlined">menu</span>
                </button>
                <h2 class="text-xl font-bold tracking-tight text-white hidden sm:block">Analytics Overview</h2>
            </div>
            <div class="flex items-center gap-6">
                <!-- Search -->
                <div class="relative hidden sm:block w-64 lg:w-96 group">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <span
                            class="material-symbols-outlined text-[#cbbc90] group-focus-within:text-primary transition-colors">search</span>
                    </div>
                    <input
                        class="block w-full pl-10 pr-3 py-2 border border-[#493f22] rounded-lg leading-5 bg-[#2d281a] text-gray-300 placeholder-[#cbbc90]/50 focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary sm:text-sm transition-all"
                        placeholder="Search orders, products..." type="text" />
                </div>
                <!-- Actions -->
                <div class="flex items-center gap-4">
                    <button
                        class="relative p-2 rounded-full hover:bg-[#493f22] text-[#cbbc90] hover:text-primary transition-colors">
                        <span class="material-symbols-outlined">notifications</span>
                        <span class="absolute top-2 right-2 flex h-2 w-2">
                            <span
                                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
                        </span>
                    </button>
                    <div class="h-8 w-[1px] bg-[#493f22]"></div>
                    <div class="flex items-center gap-3 cursor-pointer">
                        <div class="text-right hidden md:block">
                            <p class="text-sm font-medium text-white">Tariq H.</p>
                            <p class="text-xs text-[#cbbc90]">Admin</p>
                        </div>
                        <div class="bg-center bg-no-repeat bg-cover rounded-full size-9 border border-[#493f22]"
                            data-alt="Admin user profile picture"
                            style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuDUT4KT8VLrkl9ACcE6MNe1OTOFB8CxMqMCFMhBQI-MG8xd1UPg7A2WujgoYi6EtOXZqlWhOOBhmMoWDw0I6Uac5KlzHhXB6j8awfejSo8nZggD2Ak71kBfnLg0eZLKke6PQ-E45PZ36_IbgODorQXmgoS-TpBbew-sFGMjH3PU2_Awo8VvTVrjETeyLNPpmYPF1O5Mnw2scCVWmu7dNflvnRtAAH3lSkMHv2ZtVZDPsg2H2Tb_Gi5n4JEh8XtwtwFuOq1XKUf2ScYo");'>
                        </div>
                    </div>
                </div>
            </div>
        </header>
        <!-- Scrollable Content -->
        <div class="flex-1 overflow-y-auto p-8 relative z-10 scroll-smooth">
            <div class="max-w-7xl mx-auto flex flex-col gap-8">
                <!-- Quick Actions -->
                <div class="flex justify-end gap-3 mb-2">
                    <button id="export-btn"
                        class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-[#cbbc90] bg-[#2d281a] border border-[#493f22] rounded-lg hover:bg-[#3a3422] transition-colors">
                        <span class="material-symbols-outlined text-[18px]">download</span>
                        Export Report
                    </button>
                    <button
                        class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-black bg-primary rounded-lg hover:bg-primary/90 transition-colors shadow-[0_0_10px_rgba(244,192,37,0.4)]">
                        <span class="material-symbols-outlined text-[18px]">add</span>
                        Add Product
                    </button>
                </div>
                <!-- Metrics Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
                    <!-- Card 1: Total Sales -->
                    <div
                        class="glass-panel p-6 rounded-xl flex flex-col justify-between h-40 relative overflow-hidden group">
                        <div
                            class="absolute -right-4 -top-4 w-24 h-24 bg-primary/10 rounded-full blur-2xl group-hover:bg-primary/20 transition-all">
                        </div>
                        <div class="flex justify-between items-start z-10">
                            <div>
                                <p class="text-[#cbbc90] text-sm font-medium mb-1">Total Sales</p>
                                <h3 class="text-white text-3xl font-bold font-display tracking-tight">$124,500</h3>
                            </div>
                            <div class="bg-primary/20 p-2 rounded-lg text-primary">
                                <span class="material-symbols-outlined">attach_money</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2 mt-4 z-10">
                            <span
                                class="text-[#0bda1d] flex items-center text-sm font-bold bg-[#0bda1d]/10 px-2 py-0.5 rounded">
                                <span class="material-symbols-outlined text-[16px] mr-1">trending_up</span>
                                12%
                            </span>
                            <span class="text-[#cbbc90]/60 text-xs">vs last month</span>
                        </div>
                        <!-- Sparkline SVG -->
                        <canvas id="salesChart" class="w-full h-16"></canvas>
                    </div>
                    <!-- Card 2: Total Orders -->
                    <div
                        class="glass-panel p-6 rounded-xl flex flex-col justify-between h-40 relative overflow-hidden group">
                        <div
                            class="absolute -right-4 -top-4 w-24 h-24 bg-blue-500/10 rounded-full blur-2xl group-hover:bg-blue-500/20 transition-all">
                        </div>
                        <div class="flex justify-between items-start z-10">
                            <div>
                                <p class="text-[#cbbc90] text-sm font-medium mb-1">Total Orders</p>
                                <h3 class="text-white text-3xl font-bold font-display tracking-tight">1,240</h3>
                            </div>
                            <div class="bg-blue-500/20 p-2 rounded-lg text-blue-400">
                                <span class="material-symbols-outlined">shopping_bag</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2 mt-4 z-10">
                            <span
                                class="text-[#0bda1d] flex items-center text-sm font-bold bg-[#0bda1d]/10 px-2 py-0.5 rounded">
                                <span class="material-symbols-outlined text-[16px] mr-1">trending_up</span>
                                5%
                            </span>
                            <span class="text-[#cbbc90]/60 text-xs">vs last month</span>
                        </div>
                        <!-- Sparkline SVG -->
                        <svg class="absolute bottom-0 left-0 w-full h-16 opacity-20 pointer-events-none"
                            preserveaspectratio="none" viewbox="0 0 100 40">
                            <path d="M0,35 L20,30 L40,32 L60,15 L80,20 L100,10" fill="none" stroke="#60a5fa"
                                stroke-width="3"></path>
                            <path d="M0,35 L20,30 L40,32 L60,15 L80,20 L100,10 V40 H0 Z" fill="#60a5fa" opacity="0.4">
                            </path>
                        </svg>
                    </div>
                    <!-- Card 3: New Customers -->
                    <div
                        class="glass-panel p-6 rounded-xl flex flex-col justify-between h-40 relative overflow-hidden group">
                        <div
                            class="absolute -right-4 -top-4 w-24 h-24 bg-purple-500/10 rounded-full blur-2xl group-hover:bg-purple-500/20 transition-all">
                        </div>
                        <div class="flex justify-between items-start z-10">
                            <div>
                                <p class="text-[#cbbc90] text-sm font-medium mb-1">New Customers</p>
                                <h3 class="text-white text-3xl font-bold font-display tracking-tight">340</h3>
                            </div>
                            <div class="bg-purple-500/20 p-2 rounded-lg text-purple-400">
                                <span class="material-symbols-outlined">person_add</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2 mt-4 z-10">
                            <span
                                class="text-[#0bda1d] flex items-center text-sm font-bold bg-[#0bda1d]/10 px-2 py-0.5 rounded">
                                <span class="material-symbols-outlined text-[16px] mr-1">trending_up</span>
                                8%
                            </span>
                            <span class="text-[#cbbc90]/60 text-xs">vs last month</span>
                        </div>
                        <!-- Sparkline SVG -->
                        <svg class="absolute bottom-0 left-0 w-full h-16 opacity-20 pointer-events-none"
                            preserveaspectratio="none" viewbox="0 0 100 40">
                            <path d="M0,25 Q30,35 50,20 T100,15" fill="none" stroke="#c084fc" stroke-width="3"></path>
                            <path d="M0,25 Q30,35 50,20 T100,15 V40 H0 Z" fill="#c084fc" opacity="0.4"></path>
                        </svg>
                    </div>
                    <!-- Card 4: Active Products -->
                    <div
                        class="glass-panel p-6 rounded-xl flex flex-col justify-between h-40 relative overflow-hidden group">
                        <div
                            class="absolute -right-4 -top-4 w-24 h-24 bg-rose-500/10 rounded-full blur-2xl group-hover:bg-rose-500/20 transition-all">
                        </div>
                        <div class="flex justify-between items-start z-10">
                            <div>
                                <p class="text-[#cbbc90] text-sm font-medium mb-1">Active Products</p>
                                <h3 class="text-white text-3xl font-bold font-display tracking-tight">45</h3>
                            </div>
                            <div class="bg-rose-500/20 p-2 rounded-lg text-rose-400">
                                <span class="material-symbols-outlined">diamond</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2 mt-4 z-10">
                            <span
                                class="text-[#cbbc90] flex items-center text-sm font-bold bg-[#cbbc90]/10 px-2 py-0.5 rounded">
                                <span class="material-symbols-outlined text-[16px] mr-1">remove</span>
                                0%
                            </span>
                            <span class="text-[#cbbc90]/60 text-xs">vs last month</span>
                        </div>
                        <!-- Sparkline SVG -->
                        <svg class="absolute bottom-0 left-0 w-full h-16 opacity-20 pointer-events-none"
                            preserveaspectratio="none" viewbox="0 0 100 40">
                            <path d="M0,20 H100" fill="none" stroke="#fb7185" stroke-dasharray="5,5" stroke-width="3">
                            </path>
                        </svg>
                    </div>
                </div>
                <!-- Main Grid: Table and Chart -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <!-- Recent Orders Table -->
                    <div
                        class="lg:col-span-2 glass-panel rounded-xl border border-[#493f22] overflow-hidden flex flex-col">
                        <div class="p-6 border-b border-[#493f22] flex justify-between items-center">
                            <h3 class="text-white text-lg font-bold">Recent Orders</h3>
                            <a class="text-primary text-sm font-medium hover:underline" href="#">View All</a>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left">
                                <thead class="bg-[#231e10] text-[#cbbc90]">
                                    <tr>
                                        <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider">Order ID
                                        </th>
                                        <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider">Customer
                                        </th>
                                        <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider">Product
                                        </th>
                                        <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider">Date</th>
                                        <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider">Amount</th>
                                        <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider">Status</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-[#493f22]">
                                    <tr class="hover:bg-[#493f22]/20 transition-colors">
                                        <td class="px-6 py-4 text-sm font-medium text-white">#10234</td>
                                        <td class="px-6 py-4 text-sm text-[#e5e5e5]">Alice Smith</td>
                                        <td class="px-6 py-4 text-sm text-[#e5e5e5]">Chanel No. 5</td>
                                        <td class="px-6 py-4 text-sm text-[#9ca3af]">Oct 24</td>
                                        <td class="px-6 py-4 text-sm font-medium text-white">$135.00</td>
                                        <td class="px-6 py-4">
                                            <span
                                                class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-500/10 text-green-400 border border-green-500/20">
                                                Delivered
                                            </span>
                                        </td>
                                    </tr>
                                    <tr class="hover:bg-[#493f22]/20 transition-colors">
                                        <td class="px-6 py-4 text-sm font-medium text-white">#10235</td>
                                        <td class="px-6 py-4 text-sm text-[#e5e5e5]">John Doe</td>
                                        <td class="px-6 py-4 text-sm text-[#e5e5e5]">Dior Sauvage</td>
                                        <td class="px-6 py-4 text-sm text-[#9ca3af]">Oct 24</td>
                                        <td class="px-6 py-4 text-sm font-medium text-white">$110.00</td>
                                        <td class="px-6 py-4">
                                            <span
                                                class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-500/10 text-yellow-400 border border-yellow-500/20">
                                                Pending
                                            </span>
                                        </td>
                                    </tr>
                                    <tr class="hover:bg-[#493f22]/20 transition-colors">
                                        <td class="px-6 py-4 text-sm font-medium text-white">#10236</td>
                                        <td class="px-6 py-4 text-sm text-[#e5e5e5]">Emily Davis</td>
                                        <td class="px-6 py-4 text-sm text-[#e5e5e5]">Gucci Bloom</td>
                                        <td class="px-6 py-4 text-sm text-[#9ca3af]">Oct 23</td>
                                        <td class="px-6 py-4 text-sm font-medium text-white">$145.00</td>
                                        <td class="px-6 py-4">
                                            <span
                                                class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-500/10 text-blue-400 border border-blue-500/20">
                                                Shipped
                                            </span>
                                        </td>
                                    </tr>
                                    <tr class="hover:bg-[#493f22]/20 transition-colors">
                                        <td class="px-6 py-4 text-sm font-medium text-white">#10237</td>
                                        <td class="px-6 py-4 text-sm text-[#e5e5e5]">Michael Brown</td>
                                        <td class="px-6 py-4 text-sm text-[#e5e5e5]">Versace Eros</td>
                                        <td class="px-6 py-4 text-sm text-[#9ca3af]">Oct 23</td>
                                        <td class="px-6 py-4 text-sm font-medium text-white">$95.00</td>
                                        <td class="px-6 py-4">
                                            <span
                                                class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-500/10 text-purple-400 border border-purple-500/20">
                                                Processing
                                            </span>
                                        </td>
                                    </tr>
                                    <tr class="hover:bg-[#493f22]/20 transition-colors">
                                        <td class="px-6 py-4 text-sm font-medium text-white">#10238</td>
                                        <td class="px-6 py-4 text-sm text-[#e5e5e5]">Sarah Wilson</td>
                                        <td class="px-6 py-4 text-sm text-[#e5e5e5]">YSL Black Opium</td>
                                        <td class="px-6 py-4 text-sm text-[#9ca3af]">Oct 22</td>
                                        <td class="px-6 py-4 text-sm font-medium text-white">$120.00</td>
                                        <td class="px-6 py-4">
                                            <span
                                                class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-500/10 text-green-400 border border-green-500/20">
                                                Delivered
                                            </span>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <!-- Top Selling Products Chart -->
                    <div class="glass-panel rounded-xl border border-[#493f22] p-6 flex flex-col">
                        <div class="mb-6">
                            <h3 class="text-white text-lg font-bold">Top Selling Products</h3>
                            <div class="flex items-end gap-2 mt-2">
                                <h2 class="text-4xl font-bold text-primary tracking-tight">2,450</h2>
                                <span class="text-[#cbbc90] text-sm mb-1">Units Sold</span>
                            </div>
                            <div class="flex items-center gap-1 mt-1">
                                <span class="text-[#0bda1d] text-sm font-medium">+15%</span>
                                <span class="text-[#cbbc90]/60 text-sm">than last month</span>
                            </div>
                        </div>
                        <!-- Chart Visual -->
                        <div class="flex-1 min-h-[250px] relative">
                            <!-- Y-axis lines -->
                            <div
                                class="absolute inset-0 flex flex-col justify-between text-[#cbbc90]/30 text-xs pointer-events-none">
                                <div class="border-b border-dashed border-[#493f22] w-full h-0"></div>
                                <div class="border-b border-dashed border-[#493f22] w-full h-0"></div>
                                <div class="border-b border-dashed border-[#493f22] w-full h-0"></div>
                                <div class="border-b border-dashed border-[#493f22] w-full h-0"></div>
                                <div class="border-b border-[#493f22] w-full h-0"></div>
                            </div>
                            <!-- Bars Container -->
                            <div class="absolute inset-0 flex items-end justify-between px-2 pt-4">
                                <!-- Bar 1 -->
                                <div class="flex flex-col items-center gap-2 group w-1/6">
