<!DOCTYPE html>
<html class="dark" lang="en">

<head>
<%- include('../partials/head', { title: 'Shopping Cart' }) %>

</head>

<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-white antialiased min-h-screen flex flex-col">
 <%- include('../partials/header') %>

  <main class="flex-grow flex justify-center py-8 px-4 sm:px-6 lg:px-8">
    <div class="w-full max-w-[1200px] space-y-6">
      <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
        <div class="flash-message flash-success" role="alert" aria-live="polite" data-auto-dismiss="true">
          <span class="material-symbols-outlined text-base" aria-hidden="true">check_circle</span>
          <span><%= success[0] %></span>
          <button type="button" class="flash-close" aria-label="Dismiss message">
            <span class="material-symbols-outlined text-base" aria-hidden="true">close</span>
          </button>
        </div>
      <% } %>

      <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
        <div class="flash-message flash-error" role="alert" aria-live="polite">
          <span class="material-symbols-outlined text-base" aria-hidden="true">error</span>
          <span><%= error[0] %></span>
          <button type="button" class="flash-close" aria-label="Dismiss message">
            <span class="material-symbols-outlined text-base" aria-hidden="true">close</span>
          </button>
        </div>
      <% } %>

      <div class="w-full flex flex-col lg:flex-row gap-8 lg:gap-16">
        <div class="flex-1 min-w-0">
          <div class="mb-8">
            <p class="text-xs uppercase tracking-[0.2em] text-text-gold mb-2">Your selection</p>
            <h1 class="text-3xl md:text-4xl font-light tracking-tight text-white mb-2">Shopping Cart</h1>
            <p class="text-text-gold text-sm">Review your fragrances and update quantities before checkout.</p>
          </div>

          <div class="flex flex-col gap-6">
            <% if (typeof cart !== 'undefined' && cart.items.length > 0) { %>
              <% cart.items.forEach(function(item) { %>
                <article class="cart-item flex gap-4 group bg-surface-dark p-4 rounded-xl border border-surface-border shadow-sm" data-product-id="<%= item.productId %>">
                  <div class="relative size-24 shrink-0 bg-white/5 rounded-lg overflow-hidden border border-surface-border">
                    <div class="absolute inset-0 bg-gradient-to-tr from-black/40 to-transparent z-10"></div>
                    <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="<%= item.imageUrl %>" alt="<%= item.name %>">
                  </div>

                  <div class="flex flex-1 flex-col justify-center min-w-0">
                    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-2 mb-1">
                      <div class="min-w-0">
                        <h2 class="text-white font-medium text-lg leading-tight truncate"><%= item.name %></h2>
                        <p class="text-text-gold text-xs mt-1"><%= item.category %></p>
                      </div>
                      <p class="text-white font-bold text-lg shrink-0">$<%= item.price.toFixed(2) %></p>
                    </div>

                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mt-4">
                      <div class="flex items-center gap-3">
                        <span class="text-xs uppercase tracking-wider text-text-muted">Qty</span>
                        <div class="flex items-center gap-2">
                          <form action="/cart/update" method="POST" class="inline" data-cart-form="update">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="productId" value="<%= item.productId %>">
                            <input type="hidden" name="action" value="decrease">
                            <button type="submit" class="w-8 h-8 flex items-center justify-center rounded-full border border-surface-border text-zinc-400 hover:text-white hover:border-primary transition-all submit-once" aria-label="Decrease quantity for <%= item.name %>">
                              <span class="material-symbols-outlined text-sm" aria-hidden="true">remove</span>
                            </button>
                          </form>

                          <span class="cart-item-qty min-w-[2rem] text-center text-sm font-semibold text-white" aria-live="polite"><%= item.quantity %></span>

                          <form action="/cart/update" method="POST" class="inline" data-cart-form="update">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="productId" value="<%= item.productId %>">
                            <input type="hidden" name="action" value="increase">
                            <button type="submit" class="w-8 h-8 flex items-center justify-center rounded-full border border-surface-border text-zinc-400 hover:text-white hover:border-primary transition-all submit-once" aria-label="Increase quantity for <%= item.name %>">
                              <span class="material-symbols-outlined text-sm" aria-hidden="true">add</span>
                            </button>
                          </form>
                        </div>
                      </div>

                      <div class="flex items-center justify-between sm:justify-end gap-4">
                        <p class="text-xs text-text-muted">Line total <span class="cart-line-total text-white font-semibold">$<%= (item.price * item.quantity).toFixed(2) %></span></p>
                        <form action="/cart/remove" method="POST" data-cart-form="remove">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <input type="hidden" name="productId" value="<%= item.productId %>">
                          <button type="submit" class="text-xs text-red-400 hover:text-red-300 transition-colors flex items-center gap-1 submit-once">
                            <span class="material-symbols-outlined text-sm" aria-hidden="true">delete</span>
                            Remove
                          </button>
                        </form>
                      </div>
                    </div>
                  </div>
                </article>
              <% }); %>
            <% } else { %>
              <div class="text-center py-12 bg-surface-dark rounded-xl border border-surface-border">
                <span class="material-symbols-outlined text-6xl text-surface-border mb-4" aria-hidden="true">shopping_bag</span>
                <h2 class="text-xl text-white font-medium mb-2">Your bag is empty</h2>
                <p class="text-zinc-500 mb-6">Looks like you haven't added any fragrances yet.</p>
                <a href="/shop" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-background-dark font-bold rounded-lg hover:bg-primary-hover transition-colors">
                  Start Shopping
                </a>
              </div>
            <% } %>
          </div>
        </div>

        <aside class="lg:w-[400px] shrink-0">
          <div class="sticky top-24 flex flex-col gap-6">
            <div class="bg-surface-dark rounded-xl border border-surface-border p-6 shadow-xl relative overflow-hidden">
              <div class="absolute -top-20 -right-20 w-40 h-40 bg-primary/5 rounded-full blur-3xl pointer-events-none"></div>

              <h2 class="text-xl font-display font-medium text-white mb-6 border-b border-surface-border pb-4">Order Summary</h2>

              <div class="flex flex-col gap-3">
                <div class="flex justify-between text-sm text-zinc-400">
                  <span>Items</span>
                  <span class="text-white cart-count-summary"><%= typeof cart !== 'undefined' ? cart.totalQty : 0 %></span>
                </div>
                <div class="flex justify-between text-sm text-zinc-400">
                  <span>Subtotal</span>
                  <span class="text-white cart-total">$<%= (typeof cart !== 'undefined' ? cart.totalPrice : 0).toFixed(2) %></span>
                </div>
                <div class="flex justify-between text-sm text-zinc-400">
                  <span>Shipping</span>
                  <span class="text-text-gold">Calculated at checkout</span>
                </div>
                <div class="flex justify-between items-end mt-4 pt-4 border-t border-surface-border">
                  <span class="text-base font-medium text-white">Total</span>
                  <div class="flex flex-col items-end">
                    <span class="text-xs text-zinc-500 mb-1">USD</span>
                    <span class="cart-grand-total text-3xl font-bold text-primary">$<%= (typeof cart !== 'undefined' ? cart.totalPrice : 0).toFixed(2) %></span>
                  </div>
                </div>
              </div>

              <% if (typeof cart !== 'undefined' && cart.items.length > 0) { %>
                <a href="/checkout" class="w-full mt-6 px-8 py-4 bg-primary hover:bg-primary-hover text-background-dark font-bold rounded-lg transition-all shadow-[0_0_20px_rgba(244,192,37,0.3)] hover:shadow-[0_0_30px_rgba(244,192,37,0.5)] transform hover:-translate-y-0.5 flex items-center justify-center gap-2">
                  Proceed to Checkout
                  <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
                </a>
              <% } else { %>
                <a href="/shop" class="w-full mt-6 px-8 py-4 bg-primary hover:bg-primary-hover text-background-dark font-bold rounded-lg transition-all flex items-center justify-center gap-2">
                  Continue Shopping
                  <span class="material-symbols-outlined" aria-hidden="true">storefront</span>
                </a>
              <% } %>

              <div class="mt-6 flex flex-col gap-3 text-center">
                <div class="flex justify-center gap-4 text-zinc-600">
                  <span class="material-symbols-outlined" title="Secure Payment">lock</span>
                  <span class="material-symbols-outlined" title="Guaranteed Authentic">verified</span>
                  <span class="material-symbols-outlined" title="Fast Shipping">local_shipping</span>
                </div>
                <p class="text-[10px] text-zinc-600 uppercase tracking-widest">Secure checkout</p>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>

  <script src="/js/cart-logic.js" defer></script>
</body>

</html>
