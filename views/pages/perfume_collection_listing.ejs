<!DOCTYPE html>
<html class="dark" lang="en">

<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com" rel="preconnect" />
  <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/tailwind-config.js"></script>
</head>

<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-white antialiased transition-colors duration-300 min-h-screen">
  <%
    const current = Number(currentPage) || 1;
    const totalPageCount = Number(totalPages) || 1;
    const productCount = Number(total) || 0;
    const previousPage = current > 1 ? current - 1 : null;
    const nextPage = current < totalPageCount ? current + 1 : null;
    const paginationWindowStart = Math.max(1, current - 1);
    const paginationWindowEnd = Math.min(totalPageCount, current + 1);
    const paginationPages = [];

    for (let pageNumber = paginationWindowStart; pageNumber <= paginationWindowEnd; pageNumber += 1) {
      paginationPages.push(pageNumber);
    }

    function buildPageUrl(pageNumber) {
      if (!pageNumber || pageNumber < 1) {
        return '#';
      }

      if (searchQuery) {
        return `/search?q=${encodeURIComponent(searchQuery)}&page=${pageNumber}`;
      }

      return `/shop?page=${pageNumber}`;
    }
  %>

  <header class="sticky top-0 z-50 w-full border-b border-gray-200 dark:border-border-dark bg-background-light dark:bg-background-dark/95 backdrop-blur-sm">
    <div class="px-6 md:px-10 py-4 flex items-center justify-between max-w-[1440px] mx-auto">
      <div class="flex items-center gap-4">
        <a class="flex items-center gap-3 group" href="/">
          <div class="size-8 text-primary transition-transform group-hover:scale-110">
            <span class="material-symbols-outlined !text-3xl">local_florist</span>
          </div>
          <h1 class="text-xl md:text-2xl font-bold tracking-tight uppercase">Luxe Scents</h1>
        </a>
      </div>

      <div class="hidden md:flex flex-1 max-w-md mx-8">
        <form action="/search" method="GET" class="relative w-full group">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <span class="material-symbols-outlined text-text-muted group-focus-within:text-primary transition-colors">
              search
            </span>
          </div>
          <input id="collection-search" name="q" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" class="block w-full pl-10 pr-3 py-2.5 border-none rounded-lg bg-gray-100 dark:bg-surface-dark text-sm placeholder-gray-500 dark:placeholder-text-muted focus:ring-1 focus:ring-primary focus:bg-white dark:focus:bg-surface-dark transition-all" placeholder="Search for fragrances, brands..." type="text" />
        </form>
      </div>

      <div class="flex items-center gap-4">
        <a href="/wishlist" class="p-2 rounded-full hover:bg-gray-100 dark:hover:bg-surface-dark transition-colors relative group">
          <span class="material-symbols-outlined text-2xl group-hover:text-primary transition-colors">
            favorite
          </span>
        </a>

        <% if (typeof session !== 'undefined' && session.userId) { %>
          <a href="/dashboard" class="p-2 rounded-full hover:bg-gray-100 dark:hover:bg-surface-dark transition-colors relative group">
            <span class="material-symbols-outlined text-2xl group-hover:text-primary transition-colors">
              account_circle
            </span>
          </a>
        <% } else { %>
          <a href="/login" class="p-2 rounded-full hover:bg-gray-100 dark:hover:bg-surface-dark transition-colors relative group">
            <span class="material-symbols-outlined text-2xl group-hover:text-primary transition-colors">
              person
            </span>
          </a>
        <% } %>

        <a href="/cart" class="p-2 rounded-full hover:bg-gray-100 dark:hover:bg-surface-dark transition-colors relative group">
          <span class="material-symbols-outlined text-2xl group-hover:text-primary transition-colors">
            shopping_bag
          </span>

          <% if (typeof session !== 'undefined' && session.cart && session.cart.totalQty > 0) { %>
            <span class="cart-count absolute top-1 right-1 min-w-[18px] h-[18px] px-1 text-[10px] flex items-center justify-center rounded-full bg-primary text-black font-bold border-2 border-background-light dark:border-background-dark">
              <%= session.cart.totalQty %>
            </span>
          <% } %>
        </a>
      </div>
    </div>
  </header>

  <div class="px-6 md:px-10 py-4">
    <nav aria-label="Breadcrumb" class="flex text-sm text-text-muted">
      <ol class="inline-flex items-center [&>li+li]:before:content-['/'] [&>li+li]:before:mx-2">
        <li>
          <a href="/" class="hover:text-primary transition-colors">Home</a>
        </li>
        <li>
          <a href="/shop" class="hover:text-primary transition-colors">Perfumes</a>
        </li>
        <li aria-current="page" class="text-slate-800 dark:text-white font-medium">
          <%= breadcrumbCurrent %>
        </li>
      </ol>
    </nav>
  </div>

  <div class="px-6 md:px-10 pb-8">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4">
      <div class="max-w-2xl">
        <h2 class="text-4xl md:text-5xl font-black tracking-tight mb-3 text-slate-900 dark:text-white">
          <%= heading %>
        </h2>
        <p class="text-lg text-slate-600 dark:text-text-muted font-light">
          <%= description %>
        </p>
      </div>
    </div>
  </div>

  <div class="flex flex-col lg:flex-row px-6 md:px-10 pb-20 gap-10">
    <aside id="product-filter-sidebar" class="w-full lg:w-64 flex-shrink-0 space-y-8">
      <div class="lg:hidden flex justify-between items-center pb-4 border-b border-border-dark/30">
        <span class="font-bold text-lg">Filters</span>
        <div class="flex items-center gap-2">
          <button id="reset-filters-mobile" type="button" class="text-xs text-primary hover:underline">Reset Filters</button>
          <button class="flex items-center gap-2 text-primary font-bold text-sm">
            <span class="material-symbols-outlined text-xl">tune</span>
          </button>
        </div>
      </div>
      <div class="hidden lg:flex justify-between items-center pb-4 border-b border-border-dark/30">
        <span class="font-bold text-lg">Filters</span>
        <button id="reset-filters" type="button" class="text-xs text-primary hover:underline">Reset Filters</button>
      </div>
      <div class="space-y-4">
        <div class="flex justify-between items-center">
          <div>
            <h3 class="font-bold text-sm uppercase tracking-wider text-slate-900 dark:text-white">Price Range</h3>
            <p class="text-xs text-slate-500 dark:text-text-muted">Up to <span id="price-max-value" class="font-semibold">500</span></p>
          </div>
        </div>
        <div class="pt-4 pb-2">
          <input id="price-max" name="priceMax" type="range" min="50" max="500" step="5" value="500" class="w-full h-2 accent-primary" />
          <div class="flex justify-between mt-3 text-sm font-medium text-slate-600 dark:text-text-muted">
            <span>$50</span>
            <span>$500</span>
          </div>
        </div>
      </div>
      <div class="space-y-4 pt-4 border-t border-gray-200 dark:border-border-dark">
        <h3 class="font-bold text-sm uppercase tracking-wider text-slate-900 dark:text-white">Brands</h3>
        <div class="space-y-3">
          <label class="flex items-center gap-3 cursor-pointer group">
            <input name="brand" value="Chanel" class="w-5 h-5 rounded border-gray-300 dark:border-gray-600 bg-transparent text-primary focus:ring-primary focus:ring-offset-background-dark" type="checkbox" />
            <span class="text-slate-600 dark:text-text-muted group-hover:text-primary transition-colors">Chanel</span>
            <span class="ml-auto text-xs text-gray-500">(12)</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer group">
            <input name="brand" value="Tom Ford" class="w-5 h-5 rounded border-gray-300 dark:border-gray-600 bg-transparent text-primary focus:ring-primary focus:ring-offset-background-dark" type="checkbox" />
            <span class="text-slate-600 dark:text-text-muted group-hover:text-primary transition-colors">Tom Ford</span>
            <span class="ml-auto text-xs text-gray-500">(8)</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer group">
            <input name="brand" value="Dior" class="w-5 h-5 rounded border-gray-300 dark:border-gray-600 bg-transparent text-primary focus:ring-primary focus:ring-offset-background-dark" type="checkbox" />
            <span class="text-slate-600 dark:text-text-muted group-hover:text-primary transition-colors">Dior</span>
            <span class="ml-auto text-xs text-gray-500">(5)</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer group">
            <input name="brand" value="Jo Malone" class="w-5 h-5 rounded border-gray-300 dark:border-gray-600 bg-transparent text-primary focus:ring-primary focus:ring-offset-background-dark" type="checkbox" />
            <span class="text-slate-600 dark:text-text-muted group-hover:text-primary transition-colors">Jo Malone</span>
            <span class="ml-auto text-xs text-gray-500">(14)</span>
          </label>
        </div>
      </div>
      <div class="space-y-4 pt-4 border-t border-gray-200 dark:border-border-dark">
        <h3 class="font-bold text-sm uppercase tracking-wider text-slate-900 dark:text-white">Fragrance Family</h3>
        <div class="space-y-3">
          <label class="flex items-center gap-3 cursor-pointer group">
            <input name="category" value="Woody" class="w-5 h-5 rounded border-gray-300 dark:border-gray-600 bg-transparent text-primary focus:ring-primary focus:ring-offset-background-dark" type="checkbox" />
            <span class="text-slate-600 dark:text-text-muted group-hover:text-primary transition-colors">Woody</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer group">
            <input name="category" value="Floral" class="w-5 h-5 rounded border-gray-300 dark:border-gray-600 bg-transparent text-primary focus:ring-primary focus:ring-offset-background-dark" type="checkbox" />
            <span class="text-slate-600 dark:text-text-muted group-hover:text-primary transition-colors">Floral</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer group">
            <input name="category" value="Amber" class="w-5 h-5 rounded border-gray-300 dark:border-gray-600 bg-transparent text-primary focus:ring-primary focus:ring-offset-background-dark" type="checkbox" />
            <span class="text-slate-600 dark:text-text-muted group-hover:text-primary transition-colors">Amber</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer group">
            <input name="category" value="Citrus" class="w-5 h-5 rounded border-gray-300 dark:border-gray-600 bg-transparent text-primary focus:ring-primary focus:ring-offset-background-dark" type="checkbox" />
            <span class="text-slate-600 dark:text-text-muted group-hover:text-primary transition-colors">Citrus</span>
          </label>
        </div>
      </div>
    </aside>

    <main class="flex-1">
      <div class="flex flex-wrap justify-between items-center mb-6 pb-4 border-b border-gray-200 dark:border-border-dark">
        <h3 class="text-slate-900 dark:text-white font-bold text-lg">Showing <%= productCount %> result<%= productCount === 1 ? '' : 's' %></h3>
        <div class="flex items-center gap-3">
          <label class="text-sm font-medium text-slate-600 dark:text-text-muted whitespace-nowrap" for="sort">Sort By:</label>
          <div class="relative">
            <select class="appearance-none bg-transparent border border-gray-300 dark:border-border-dark text-slate-900 dark:text-white rounded-lg py-2 pl-4 pr-10 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary cursor-pointer" id="sort">
              <option>Best Selling</option>
              <option>Price: Low to High</option>
              <option>Price: High to Low</option>
              <option>Newest Arrivals</option>
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-primary">
              <span class="material-symbols-outlined text-xl">expand_more</span>
            </div>
          </div>
        </div>
      </div>

      <div class="products-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% if (typeof products !== 'undefined' && products.length > 0) { %>
          <% products.forEach(function(product) { %>
            <%- include('../partials/product_card', { product: product }) %>
          <% }); %>
        <% } else { %>
          <div class="col-span-full text-center py-20">
            <h3 class="text-xl font-bold text-slate-400">No products found.</h3>
          </div>
        <% } %>
      </div>

      <% if (totalPageCount > 1) { %>
        <div class="flex justify-center mt-12">
          <div class="flex items-center gap-2">
            <% if (previousPage) { %>
              <a href="<%= buildPageUrl(previousPage) %>" class="w-10 h-10 flex items-center justify-center rounded-lg border border-gray-300 dark:border-border-dark text-slate-600 dark:text-text-muted hover:bg-gray-100 dark:hover:bg-surface-dark transition-colors" aria-label="Previous page">
                <span class="material-symbols-outlined text-sm">arrow_back_ios_new</span>
              </a>
            <% } else { %>
              <span class="w-10 h-10 flex items-center justify-center rounded-lg border border-gray-200 dark:border-border-dark/50 text-slate-300 dark:text-text-muted/40 cursor-not-allowed">
                <span class="material-symbols-outlined text-sm">arrow_back_ios_new</span>
              </span>
            <% } %>

            <% if (paginationWindowStart > 1) { %>
              <a href="<%= buildPageUrl(1) %>" class="w-10 h-10 flex items-center justify-center rounded-lg border border-gray-300 dark:border-border-dark text-slate-600 dark:text-text-muted hover:bg-gray-100 dark:hover:bg-surface-dark transition-colors hover:text-primary">1</a>
              <% if (paginationWindowStart > 2) { %>
                <span class="px-2 text-text-muted">...</span>
              <% } %>
            <% } %>

            <% paginationPages.forEach(function(pageNumber) { %>
              <% if (pageNumber === current) { %>
                <span class="w-10 h-10 flex items-center justify-center rounded-lg bg-primary text-slate-900 font-bold shadow-md"><%= pageNumber %></span>
              <% } else { %>
                <a href="<%= buildPageUrl(pageNumber) %>" class="w-10 h-10 flex items-center justify-center rounded-lg border border-gray-300 dark:border-border-dark text-slate-600 dark:text-text-muted hover:bg-gray-100 dark:hover:bg-surface-dark transition-colors hover:text-primary"><%= pageNumber %></a>
              <% } %>
            <% }); %>

            <% if (paginationWindowEnd < totalPageCount) { %>
              <% if (paginationWindowEnd < totalPageCount - 1) { %>
                <span class="px-2 text-text-muted">...</span>
              <% } %>
              <a href="<%= buildPageUrl(totalPageCount) %>" class="w-10 h-10 flex items-center justify-center rounded-lg border border-gray-300 dark:border-border-dark text-slate-600 dark:text-text-muted hover:bg-gray-100 dark:hover:bg-surface-dark transition-colors hover:text-primary"><%= totalPageCount %></a>
            <% } %>

            <% if (nextPage) { %>
              <a href="<%= buildPageUrl(nextPage) %>" class="w-10 h-10 flex items-center justify-center rounded-lg border border-gray-300 dark:border-border-dark text-slate-600 dark:text-text-muted hover:bg-gray-100 dark:hover:bg-surface-dark transition-colors" aria-label="Next page">
                <span class="material-symbols-outlined text-sm">arrow_forward_ios</span>
              </a>
            <% } else { %>
              <span class="w-10 h-10 flex items-center justify-center rounded-lg border border-gray-200 dark:border-border-dark/50 text-slate-300 dark:text-text-muted/40 cursor-not-allowed">
                <span class="material-symbols-outlined text-sm">arrow_forward_ios</span>
              </span>
            <% } %>
          </div>
        </div>
      <% } %>
    </main>

    
  </div>

  <script src="/js/collection-filters.js" defer></script>
</body>

</html>
