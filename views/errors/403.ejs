<!DOCTYPE html>
<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>403 — Access Denied | Luxe Scents</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-background-dark text-white antialiased min-h-screen flex flex-col items-center justify-center">
    <div class="text-center px-6">
        <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-2xl bg-amber-500/10 text-amber-400">
            <span class="material-symbols-outlined text-5xl">lock</span>
        </div>
        <h1 class="text-7xl font-bold text-amber-400 mb-4">403</h1>
        <h2 class="text-2xl font-light text-white mb-4">Access Denied</h2>
        <p class="text-zinc-400 mb-8 max-w-md mx-auto">
            <%= typeof message !=='undefined' ? message : 'You do not have permission to view this page.' %>
        </p>
        <a href="/"
            class="inline-flex items-center gap-2 px-8 py-3 bg-primary text-background-dark font-bold rounded-lg hover:bg-amber-400 transition-colors">
            <span class="material-symbols-outlined">home</span>
            Back to Store
        </a>
    </div>
</body>

</html>